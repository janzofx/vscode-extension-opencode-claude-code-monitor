{
  "name": "agent-observatory",
  "displayName": "Agent Observatory",
  "description": "Read-only monitoring dashboard for Claude Code and OpenCode sessions in VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/agent-observatory.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "agent-observatory.openPanel",
        "title": "Agent Observatory: Open Panel",
        "icon": "$(pulse)"
      }
    ],
    "configuration": {
      "title": "Agent Observatory",
      "properties": {
        "agentObservatory.hooksPort": {
          "type": "number",
          "default": 3001,
          "minimum": 1,
          "maximum": 65535,
          "description": "Port used for Claude Code hook events."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "css-loader": "^7.1.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.4.2",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "@types/express": "^4.17.17",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@xyflow/react": "^12.10.1",
    "express": "^4.18.2",
    "path-browserify": "^1.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0"
  }
}
